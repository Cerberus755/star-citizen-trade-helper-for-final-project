<UserControl x:Class="StarCitizenTrader.Views.NegotiationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White" Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" Text="💬 Negotiations" FontSize="22" FontWeight="Bold" 
                       Foreground="#FFE94560"/>
            <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}" 
                    Style="{StaticResource HeaderButton}" Content="🔄 Refresh"/>
            <TextBlock/>
        </DockPanel>

        <!-- No Auth Warning -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" 
                Visibility="{Binding HasAuth, Converter={StaticResource InvBoolVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🔒" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Authentication Required" FontSize="18" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Negotiations require both a Bearer Token and Secret Key." 
                           Foreground="#99FFFFFF" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Go to Settings to configure your API credentials." 
                           Foreground="#99FFFFFF" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content (when authenticated) -->
        <Grid Grid.Row="1" Visibility="{Binding HasAuth, Converter={StaticResource BoolVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Negotiations List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Active Deals" FontSize="14" FontWeight="SemiBold" 
                               Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding Negotiations}" 
                             SelectedItem="{Binding SelectedNegotiation}"
                             Background="Transparent" BorderThickness="0" Foreground="White"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1AFFFFFF" CornerRadius="4" Padding="10,8" Margin="0,2"
                                        Width="310">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding ListingTitle}" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis" FontSize="12"/>
                                        <TextBlock Grid.Row="1" FontSize="11" Foreground="#CCFFFFFF">
                                            <Run Text="With: "/><Run Text="{Binding CounterpartyUsername, Mode=OneWay}" FontWeight="Medium"/>
                                        </TextBlock>
                                        <DockPanel Grid.Row="2" Margin="0,2,0,0">
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding FormattedPrice}" 
                                                       FontWeight="Bold" Foreground="#FF4FC3F7" FontSize="12"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusDisplay}" 
                                                       FontSize="10" HorizontalAlignment="Right"/>
                                            <TextBlock/>
                                        </DockPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Chat Panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <!-- Chat header -->
                    <Border DockPanel.Dock="Top" Background="#1AFFFFFF" CornerRadius="4" Padding="10,8" 
                            Margin="0,0,0,8"
                            Visibility="{Binding SelectedNegotiation, Converter={StaticResource NotNullToVisibility}}">
                        <StackPanel DataContext="{Binding SelectedNegotiation}">
                            <TextBlock Text="{Binding ListingTitle}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock FontSize="11" Foreground="#99FFFFFF">
                                <Run Text="{Binding FormattedPrice, Mode=OneWay}"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Message input -->
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0"
                               Visibility="{Binding SelectedNegotiation, Converter={StaticResource NotNullToVisibility}}">
                        <Button DockPanel.Dock="Right" Command="{Binding SendMessageCommand}" 
                                Style="{StaticResource AccentButton}" Content="Send" Width="70" Margin="8,0,0,0"/>
                        <TextBox Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}" Tag="Type a message..."
                                 AcceptsReturn="False"/>
                    </DockPanel>

                    <!-- Messages -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="10,6" CornerRadius="8"
                                            Background="#1AFFFFFF" MaxWidth="500" HorizontalAlignment="Left">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" FontSize="11" FontWeight="SemiBold"
                                                           Text="{Binding UserUsername}" Foreground="#FFE94560"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding TimeDisplay}" 
                                                           FontSize="9" Foreground="#66FFFFFF" Margin="12,0,0,0"/>
                                                <TextBlock/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
