<Application x:Class="StarCitizenTrader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StarCitizenTrader.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══════════════════════════════════════════════════
                 CONVERTERS
                 ═══════════════════════════════════════════════════ -->
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
            <conv:UnixTimestampConverter x:Key="TimestampFmt"/>
            <conv:PriceFormatter x:Key="PriceFmt"/>
            <conv:PriceChangeColorConverter x:Key="PriceChangeColor"/>
            <conv:OperationColorConverter x:Key="OpColor"/>
            <conv:NullableDoubleConverter x:Key="NullDoubleFmt"/>
            <conv:EqualityConverter x:Key="EqualConv"/>
            
            <!-- BoolToGreenRed for connection indicator -->
            <conv:BoolToVisibilityConverter x:Key="BoolToGreenRedHelper"/>

            <!-- Not-null to visibility -->
            <Style x:Key="NotNullVisStyle" TargetType="FrameworkElement">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- ═══════════════════════════════════════════════════
                 COLOR PALETTE (Star Citizen / Space theme)
                 ═══════════════════════════════════════════════════ -->
            <Color x:Key="BgDark">#FF1A1A2E</Color>
            <Color x:Key="BgMedium">#FF16213E</Color>
            <Color x:Key="BgSidebar">#FF0F3460</Color>
            <Color x:Key="Accent">#FFE94560</Color>
            <Color x:Key="AccentLight">#FFFF6B6B</Color>
            <Color x:Key="TextPrimary">#FFFFFFFF</Color>
            <Color x:Key="TextSecondary">#99FFFFFF</Color>
            <Color x:Key="PriceBlue">#FF4FC3F7</Color>
            <Color x:Key="Green">#FF4CAF50</Color>
            <Color x:Key="Red">#FFF44336</Color>

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
            <SolidColorBrush x:Key="PriceBlueBrush" Color="{StaticResource PriceBlue}"/>

            <!-- ═══════════════════════════════════════════════════
                 CUSTOM VALUE CONVERTERS (inline)
                 ═══════════════════════════════════════════════════ -->
            <!-- Bool→Green/Red Ellipse fill -->
            <Style x:Key="ConnectionDot" TargetType="Ellipse">
                <Setter Property="Fill" Value="#FFF44336"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Fill" Value="#FF4CAF50"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Positive int → Visibility (for notification badge) -->
            <conv:BoolToVisibilityConverter x:Key="PositiveToVisibility"/>

            <!-- NotNull → Bool -->
            <conv:BoolToVisibilityConverter x:Key="NotNullToBool"/>

            <!-- NotNull → Visibility  -->
            <conv:BoolToVisibilityConverter x:Key="NotNullToVisibility"/>

            <!-- Inverse bool converter -->
            <conv:InverseBoolToVisibilityConverter x:Key="InvBool"/>

            <!-- BoolToGreenRed for connection dot -->
            <conv:OperationColorConverter x:Key="BoolToGreenRed"/>

            <!-- ═══════════════════════════════════════════════════
                 GLOBAL STYLES
                 ═══════════════════════════════════════════════════ -->

            <!-- Card container -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="#FF16213E"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="14"/>
            </Style>

            <!-- Card metric label -->
            <Style x:Key="CardLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#99FFFFFF"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- Card metric value -->
            <Style x:Key="CardValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <!-- Field label -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- ═══ NAVIGATION BUTTON ═══ -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#22E94560"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ HEADER BUTTON (ghost style) ═══ -->
            <Style x:Key="HeaderButton" TargetType="Button">
                <Setter Property="Background" Value="#33FFFFFF"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ ACCENT BUTTON (primary action) ═══ -->
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFFF6B6B"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ DANGER BUTTON ═══ -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="#44F44336"/>
                <Setter Property="Foreground" Value="#FFF44336"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#66F44336"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ MODERN TEXTBOX ═══ -->
            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="#33FFFFFF"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <TextBlock x:Name="Placeholder" Text="{TemplateBinding Tag}"
                                               Foreground="#55FFFFFF" FontSize="{TemplateBinding FontSize}"
                                               VerticalAlignment="Center" Margin="2,0,0,0"
                                               Visibility="Collapsed"/>
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Text" Value=""/>
                                        <Condition Property="IsFocused" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ MODERN COMBOBOX ═══ -->
            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="#33FFFFFF"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- ═══ MODERN DATAGRID ═══ -->
            <Style x:Key="ModernDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1AFFFFFF"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="#0AFFFFFF"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="RowHeight" Value="34"/>
            </Style>

            <!-- DataGrid Column Header -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#22FFFFFF"/>
                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- DataGrid Cell -->
            <Style TargetType="DataGridCell">
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#33E94560"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- DataGrid Row -->
            <Style TargetType="DataGridRow">
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1AFFFFFF"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#22E94560"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ScrollBar dark theme -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="8"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
