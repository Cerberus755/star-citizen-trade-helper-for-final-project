<Window x:Class="StarCitizenTrader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StarCitizenTrader.Views"
        xmlns:vm="clr-namespace:StarCitizenTrader.ViewModels"
        Title="Star Citizen Trader — UEX Marketplace" 
        Height="800" Width="1280" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF1A1A2E">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ListingsViewModel}">
            <views:ListingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WishlistViewModel}">
            <views:WishlistView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NegotiationsViewModel}">
            <views:NegotiationsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ═══ TOP HEADER BAR ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FF16213E" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🚀" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="STAR CITIZEN TRADER" FontSize="18" FontWeight="Bold" 
                               Foreground="#FFE94560" VerticalAlignment="Center"/>
                    <TextBlock Text=" — UEX Marketplace" FontSize="13" Foreground="#99FFFFFF" 
                               VerticalAlignment="Center" Margin="4,0,0,2"/>
                </StackPanel>
                
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Notification badge -->
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderButton}" 
                            Content="🔄 Refresh" Margin="0,0,12,0"/>
                    <Border Background="#33E94560" CornerRadius="12" Padding="10,4" Margin="0,0,12,0"
                            Visibility="{Binding UnreadNotifications, Converter={StaticResource PositiveToVisibility}}">
                        <TextBlock Foreground="#FFE94560" FontWeight="Bold">
                            <Run Text="🔔 "/>
                            <Run Text="{Binding UnreadNotifications, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <!-- Connection indicator -->
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToGreenRed}}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#99FFFFFF" FontSize="11" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock/><!-- spacer -->
            </DockPanel>
        </Border>
        
        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Background="#FF0F3460" Padding="0,8">
            <StackPanel>
                <Button Command="{Binding NavigateDashboardCommand}" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateListingsCommand}" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Active Listings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateWishlistCommand}" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⭐" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Wishlist" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateNegotiationsCommand}" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💬" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Negotiations" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Separator Background="#33FFFFFF" Margin="12,8"/>
                
                <Button Command="{Binding NavigateSettingsCommand}" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Recent Notifications mini-panel -->
                <Separator Background="#33FFFFFF" Margin="12,8"/>
                <TextBlock Text="  Recent Alerts" Foreground="#99FFFFFF" FontSize="11" Margin="12,4,0,4"/>
                <ItemsControl ItemsSource="{Binding RecentNotifications}" Margin="8,0"
                              MaxHeight="250">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1AFFFFFF" CornerRadius="4" Padding="6,4" Margin="0,2">
                                <StackPanel>
                                    <TextBlock FontSize="10" Foreground="#CCFFFFFF" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding TypeIcon, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Title, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding TimeAgo}" FontSize="9" Foreground="#66FFFFFF"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
        
        <!-- ═══ MAIN CONTENT AREA ═══ -->
        <Border Grid.Row="1" Grid.Column="1" Padding="16">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
        
        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Grid.Column="1" Background="#FF16213E" Padding="12,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding CurrentViewName}" 
                           Foreground="#99FFFFFF" FontSize="11"/>
                <TextBlock DockPanel.Dock="Right" Foreground="#66FFFFFF" FontSize="10"
                           HorizontalAlignment="Right" Text="UEX Corps API 2.0 • SC 4.8"/>
                <TextBlock/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
