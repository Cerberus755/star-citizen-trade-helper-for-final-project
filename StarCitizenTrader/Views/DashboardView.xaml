<UserControl x:Class="StarCitizenTrader.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StarCitizenTrader.Converters"
             Foreground="White">

    <UserControl.Resources>
        <conv:PriceFormatter x:Key="PriceFmt"/>
        <conv:NullableDoubleConverter x:Key="NullDoubleFmt"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Dashboard" FontSize="22" FontWeight="Bold" 
                   Foreground="#FFE94560" Margin="0,0,0,12"/>

        <!-- ═══ SUMMARY CARDS ═══ -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">
            <!-- Total Listings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Active Listings" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding TotalListings}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <!-- Trending Items -->
            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Trending Items" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding TotalTrends}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <!-- Wishlist Tracking -->
            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Wishlist Items" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding ActiveWishlistItems}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <!-- Last Update -->
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Last Update" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding LastUpdateText}" Style="{StaticResource CardValue}" FontSize="18"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Trending Items Table -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="🔥 Top Trending Items" FontSize="14" 
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding TopTrends}" AutoGenerateColumns="False"
                              IsReadOnly="True" Style="{StaticResource ModernDataGrid}"
                              HeadersVisibility="Column" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                            <DataGridTextColumn Header="Avg Sell" Width="90"
                                Binding="{Binding PriceAvgSell, Converter={StaticResource NullDoubleFmt}}"/>
                            <DataGridTextColumn Header="Avg Buy" Width="90"
                                Binding="{Binding PriceAvgBuy, Converter={StaticResource NullDoubleFmt}}"/>
                            <DataGridTextColumn Header="Listings" Binding="{Binding TotalListingsCount}" Width="65"/>
                            <DataGridTextColumn Header="Deals" Binding="{Binding NegotiationsSuccess}" Width="55"/>
                            <DataGridTextColumn Header="Trend" Binding="{Binding TrendIndicator}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right Column: Recent Listings + Matches -->
            <StackPanel Grid.Column="1">
                <!-- Recent Listings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" MaxHeight="300">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📦 Recent Listings" FontSize="14"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding RecentListings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1AFFFFFF" CornerRadius="4" Padding="8,6" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Title}" FontWeight="Medium" 
                                                           TextTrimming="CharacterEllipsis" FontSize="12"/>
                                                <TextBlock FontSize="10" Foreground="#99FFFFFF">
                                                    <Run Text="{Binding OperationDisplay, Mode=OneWay}"/>
                                                    <Run Text=" • "/>
                                                    <Run Text="{Binding UserUsername, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedPricePerUnit}" 
                                                       FontWeight="Bold" Foreground="#FF4FC3F7" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Recent Wishlist Matches -->
                <Border Style="{StaticResource CardStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="⭐ Recent Wishlist Matches" FontSize="14"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding RecentMatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1AE94560" CornerRadius="4" Padding="8,6" Margin="0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ListingTitle}" FontWeight="Medium" 
                                                       TextTrimming="CharacterEllipsis" FontSize="12"/>
                                            <TextBlock FontSize="10" Foreground="#CCFFFFFF">
                                                <Run Text="{Binding Price, StringFormat='{}{0:N0}', Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Currency, Mode=OneWay}"/>
                                                <Run Text=" • by "/>
                                                <Run Text="{Binding SellerUsername, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Loading indicator -->
        <Border Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                Padding="8,4" Background="#33E94560" CornerRadius="4" Margin="0,8,0,0"
                HorizontalAlignment="Center">
            <TextBlock Text="⏳ Loading data..." Foreground="#FFE94560" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
